<Window x:Class="guideXOS_Hypervisor_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guideXOS_Hypervisor_GUI"
        xmlns:views="clr-namespace:guideXOS_Hypervisor_GUI.Views"
        xmlns:vm="clr-namespace:guideXOS_Hypervisor_GUI.ViewModels"
        xmlns:converters="clr-namespace:guideXOS_Hypervisor_GUI.Converters"
        mc:Ignorable="d"
        Title="guideXOS Hypervisor Manager" 
        Height="768" Width="1280"
        MinHeight="600" MinWidth="1024"
        Background="{StaticResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToReadWriteConverter x:Key="BoolToReadWriteConverter"/>
    </Window.Resources>
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar - VirtualBox Style with 8px Grid System -->
        <Border Grid.Row="0" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- VM Management Group -->
                <Border Background="{StaticResource BackgroundLightBrush}" 
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="0,0,8,0">
                    <Button Content="⊕ New" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding NewVMCommand}"
                            ToolTip="Create a new virtual machine"
                            Padding="12,6"
                            Margin="0"/>
                </Border>
                
                <!-- VM Control Group -->
                <Border Background="{StaticResource BackgroundLightBrush}" 
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶ Start" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding StartVMCommand}"
                                ToolTip="Start selected virtual machine"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="⏸ Pause" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding PauseVMCommand}"
                                ToolTip="Pause selected virtual machine"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="⏹ Stop" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding StopVMCommand}"
                                ToolTip="Stop selected virtual machine"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="↻ Reset" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding ResetVMCommand}"
                                ToolTip="Reset selected virtual machine"
                                Padding="12,6"
                                Margin="0"/>
                    </StackPanel>
                </Border>
                
                <!-- VM Tools Group -->
                <Border Background="{StaticResource BackgroundLightBrush}" 
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📷 Snapshot" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding SnapshotVMCommand}"
                                ToolTip="Manage snapshots"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="⚙ Settings" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding SettingsVMCommand}"
                                ToolTip="VM Settings"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="🖥 Show Screen" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding ShowScreenCommand}"
                                ToolTip="Show virtual machine screen"
                                Padding="12,6"
                                Margin="0"/>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>
                        <Button Content="🐛 Debug" 
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding DebugVMCommand}"
                                ToolTip="Open debugger"
                                Padding="12,6"
                                Margin="0"/>
                    </StackPanel>
                </Border>
                
                <!-- Delete Group -->
                <Border Background="{StaticResource BackgroundLightBrush}" 
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,4">
                    <Button Content="🗑 Delete" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding DeleteVMCommand}"
                            ToolTip="Delete virtual machine"
                            Padding="12,6"
                            Margin="0"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - VM List (Fixed 260px with 8px Grid) -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- VM List Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Text="Virtual Machines"
                                   Style="{StaticResource SubHeaderTextStyle}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                    </Border>

                    <!-- Search Box -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BackgroundMediumBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,12">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="{StaticResource BackgroundDarkBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 FontSize="12"/>
                    </Border>

                    <!-- VM List -->
                    <ListBox ItemsSource="{Binding FilteredVirtualMachines}"
                             SelectedItem="{Binding SelectedVM}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource VMListItemStyle}">
                        <ListBox.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}">
                                <MenuItem Header="Start" 
                                          Command="{Binding StartVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <MenuItem Header="Pause" 
                                          Command="{Binding PauseVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <MenuItem Header="Stop" 
                                          Command="{Binding StopVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <MenuItem Header="Reset" 
                                          Command="{Binding ResetVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <Separator Style="{StaticResource ModernMenuSeparator}"/>
                                <MenuItem Header="Snapshots..." 
                                          Command="{Binding SnapshotVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <MenuItem Header="Settings..." 
                                          Command="{Binding SettingsVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                                <Separator Style="{StaticResource ModernMenuSeparator}"/>
                                <MenuItem Header="Delete" 
                                          Command="{Binding DeleteVMCommand}"
                                          Style="{StaticResource ModernMenuItem}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- State Indicator -->
                                    <Ellipse Grid.Row="0" Grid.Column="0"
                                             Width="10" Height="10"
                                             Margin="0,0,12,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding StateColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- VM Name -->
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Name}"
                                               Style="{StaticResource NormalTextStyle}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- VM State -->
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding StateDescription}"
                                               Style="{StaticResource SecondaryTextStyle}"
                                               FontSize="11"
                                               Margin="0,4,0,0"/>

                                    <!-- VM Specs -->
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Style="{StaticResource SecondaryTextStyle}"
                                               FontSize="10"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Architecture, Mode=OneWay}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding CpuCount, StringFormat='{}{0} CPU', Mode=OneWay}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding MemoryDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Resizable Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE"/>

            <!-- Main Panel - VM Details -->
            <TabControl Grid.Column="2"
                        Style="{StaticResource ModernTabControl}"
                        SelectedIndex="0">
                
                <!-- GENERAL Tab -->
                <TabItem Header="General" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- VM Name Header -->
                            <TextBlock Text="{Binding DetailsViewModel.Name}"
                                       Style="{StaticResource HeaderTextStyle}"
                                       Margin="0,0,0,20"/>

                            <!-- General Information Card -->
                            <GroupBox Header="GENERAL" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.Name}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="UUID:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailsViewModel.UUID}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ISA Type:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetailsViewModel.ISAType}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Current State:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetailsViewModel.StateDescription}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontWeight="Bold"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Operating System:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetailsViewModel.OperatingSystem}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- SYSTEM Tab -->
                <TabItem Header="System" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- System Configuration Card -->
                            <GroupBox Header="SYSTEM" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU Count:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.CpuCount}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Memory Size:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailsViewModel.MemoryDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="MMU Enabled:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetailsViewModel.MMUStatus}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Page Size:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetailsViewModel.PageSizeDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- CPU Tab -->
                <TabItem Header="CPU" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- CPU State Card -->
                            <GroupBox Header="CPU STATE" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Current IP:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.CurrentIPDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cycle Counter:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailsViewModel.TotalCycles, StringFormat='{}{0:N0}'}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Frame Marker:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetailsViewModel.CFMDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Processor Status:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetailsViewModel.PSRDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>
                                </Grid>
                            </GroupBox>

                            <!-- General Registers Card -->
                            <GroupBox Header="GENERAL REGISTERS (GR0-GR7)" Style="{StaticResource ModernGroupBox}">
                                <ItemsControl ItemsSource="{Binding DetailsViewModel.GeneralRegistersDisplay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource NormalTextStyle}" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <!-- Floating Point Registers Card -->
                            <GroupBox Header="FLOATING-POINT REGISTERS (FR0-FR7)" Style="{StaticResource ModernGroupBox}">
                                <ItemsControl ItemsSource="{Binding DetailsViewModel.FloatRegistersDisplay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource NormalTextStyle}" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <!-- Predicate Registers Card -->
                            <GroupBox Header="PREDICATE REGISTERS (PR0-PR15)" Style="{StaticResource ModernGroupBox}">
                                <ItemsControl ItemsSource="{Binding DetailsViewModel.PredicateRegistersDisplay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,15,2">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource NormalTextStyle}" FontWeight="Bold" Width="40"/>
                                                <TextBlock Text="{Binding Value}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <!-- Branch Registers Card -->
                            <GroupBox Header="BRANCH REGISTERS (BR0-BR7)" Style="{StaticResource ModernGroupBox}">
                                <ItemsControl ItemsSource="{Binding DetailsViewModel.BranchRegistersDisplay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource NormalTextStyle}" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- STORAGE Tab -->
                <TabItem Header="Storage" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- Disk Images Card -->
                            <GroupBox Header="ATTACHED DISK IMAGES" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding DetailsViewModel.DiskImages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BackgroundLightBrush}" 
                                                        BorderBrush="{StaticResource BorderBrush}" 
                                                        BorderThickness="1" 
                                                        Padding="10" 
                                                        Margin="0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Type}" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path}" Style="{StaticResource NormalTextStyle}" Margin="0,2" TextWrapping="Wrap"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Size:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SizeMB, StringFormat='{}{0} MB'}" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>

                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource NormalTextStyle}" Margin="0,2">
                                                            <Run Text="{Binding ReadOnly, Converter={StaticResource BoolToReadWriteConverter}}"/>
                                                            <Run Text=" • "/>
                                                            <Run Text="{Binding Controller}"/>
                                                            <Run Text=" Port "/>
                                                            <Run Text="{Binding Port}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <TextBlock Text="No disk images attached" 
                                               Style="{StaticResource SecondaryTextStyle}"
                                               Margin="10"
                                               Visibility="{Binding DetailsViewModel.HasDiskImages, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- PERFORMANCE Tab -->
                <TabItem Header="Performance" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- Execution Statistics Card -->
                            <GroupBox Header="EXECUTION STATISTICS" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Cycles:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.TotalCycles, StringFormat='{}{0:N0}'}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cycles/Second:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailsViewModel.CyclesPerSecondDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Instructions:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetailsViewModel.TotalInstructions, StringFormat='{}{0:N0}'}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Average IPC:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetailsViewModel.IPCDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Execution Time:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetailsViewModel.ExecutionTimeDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>
                                </Grid>
                            </GroupBox>

                            <!-- Memory Access Statistics Card -->
                            <GroupBox Header="MEMORY ACCESS STATS" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cache Hit Rate:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.CacheHitRateDisplay}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>
                                </Grid>
                            </GroupBox>

                            <!-- Hot Paths Card -->
                            <GroupBox Header="HOT PATH LIST" Style="{StaticResource ModernGroupBox}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hottest Function:" Style="{StaticResource NormalTextStyle}" Margin="0,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailsViewModel.HottestFunction}" Style="{StaticResource NormalTextStyle}" Margin="0,5" FontFamily="Consolas"/>
                                </Grid>
                            </GroupBox>

                            <!-- Instruction Frequency Placeholder -->
                            <GroupBox Header="INSTRUCTION FREQUENCY" Style="{StaticResource ModernGroupBox}">
                                <TextBlock Text="Profiler chart integration coming soon..." 
                                           Style="{StaticResource SecondaryTextStyle}"
                                           Margin="10"/>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- PERFORMANCE MONITOR Tab -->
                <TabItem Header="Performance Monitor" Style="{StaticResource ModernTabItem}">
                    <views:PerformanceMonitorView DataContext="{Binding PerformanceMonitorViewModel}"/>
                </TabItem>

                <!-- DEBUG Tab -->
                <TabItem Header="Debug" Style="{StaticResource ModernTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- Breakpoints Card -->
                            <GroupBox Header="BREAKPOINTS" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding DetailsViewModel.Breakpoints}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BackgroundLightBrush}" 
                                                        BorderBrush="{StaticResource BorderBrush}" 
                                                        BorderThickness="1" 
                                                        Padding="8" 
                                                        Margin="0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Address, StringFormat='0x{0:X16}'}" Style="{StaticResource NormalTextStyle}" Margin="0,2" FontFamily="Consolas"/>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enabled:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Enabled}" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Hit Count:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HitCount}" Style="{StaticResource NormalTextStyle}" Margin="0,2" FontFamily="Consolas"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <TextBlock Text="No breakpoints set" 
                                               Style="{StaticResource SecondaryTextStyle}"
                                               Margin="10"
                                               Visibility="{Binding DetailsViewModel.HasBreakpoints, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Watchpoints Card -->
                            <GroupBox Header="WATCHPOINTS" Style="{StaticResource ModernGroupBox}">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding DetailsViewModel.Watchpoints}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BackgroundLightBrush}" 
                                                        BorderBrush="{StaticResource BorderBrush}" 
                                                        BorderThickness="1" 
                                                        Padding="8" 
                                                        Margin="0,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Address Range:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource NormalTextStyle}" Margin="0,2" FontFamily="Consolas">
                                                            <Run Text="{Binding AddressStart, StringFormat='0x{0:X16}'}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding AddressEnd, StringFormat='0x{0:X16}'}"/>
                                                        </TextBlock>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Type}" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Enabled:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Enabled}" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>

                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Hit Count:" Style="{StaticResource NormalTextStyle}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding HitCount}" Style="{StaticResource NormalTextStyle}" Margin="0,2" FontFamily="Consolas"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <TextBlock Text="No watchpoints set" 
                                               Style="{StaticResource SecondaryTextStyle}"
                                               Margin="10"
                                               Visibility="{Binding DetailsViewModel.HasWatchpoints, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Step Execution Controls -->
                            <GroupBox Header="STEP EXECUTION CONTROLS" Style="{StaticResource ModernGroupBox}">
                                <TextBlock Text="Debug step controls integration coming soon..." 
                                           Style="{StaticResource SecondaryTextStyle}"
                                           Margin="10"/>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar - VirtualBox Style with Live Metrics -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message with Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="●" 
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource NormalTextStyle}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Live VM Metrics - Professional 8px Grid -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Total VMs -->
                    <Border Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" FontSize="11" VerticalAlignment="Center">
                                <Run Text="Total:"/>
                                <Run Text="{Binding TotalVMs, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Running VMs -->
                    <Border Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#4CAF50"/>
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" FontSize="11" VerticalAlignment="Center">
                                <Run Text="Running:"/>
                                <Run Text="{Binding RunningVMs, Mode=OneWay}" FontWeight="SemiBold" Foreground="#4CAF50"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Active CPUs -->
                    <Border Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" FontSize="11" VerticalAlignment="Center">
                                <Run Text="CPUs:"/>
                                <Run Text="{Binding ActiveCPUs, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Total Memory -->
                    <Border Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" FontSize="11" VerticalAlignment="Center">
                                <Run Text="Memory:"/>
                                <Run Text="{Binding TotalMemoryAllocated, StringFormat='{}{0} MB', Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

