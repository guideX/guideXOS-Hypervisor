<Window x:Class="guideXOS_Hypervisor_GUI.Views.VMSettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:guideXOS_Hypervisor_GUI.Views"
        xmlns:vm="clr-namespace:guideXOS_Hypervisor_GUI.ViewModels"
        mc:Ignorable="d"
        Title="Virtual Machine Settings" 
        Height="700" Width="1000"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedCategoryButtonStyle" TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="Categories"
                               Style="{StaticResource SubHeaderTextStyle}"
                               Margin="16,0,16,12"/>
                    
                    <Button Content="&#x2699; General"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="General"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F4BB; System"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="System"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F5A5; Display"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="Display"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F4BE; Storage"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="Storage"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F310; Network"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="Network"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F680; Performance"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="Performance"
                            Style="{StaticResource CategoryButtonStyle}"/>
                    
                    <Button Content="&#x1F527; Advanced"
                            Command="{Binding SelectedCategoryCommand}"
                            CommandParameter="Advanced"
                            Style="{StaticResource CategoryButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Settings Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,20,32,20">
                    
                    <!-- General Settings -->
                    <StackPanel x:Name="GeneralSettings" Visibility="Visible">
                        <TextBlock Text="General Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="BASIC INFORMATION" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBoxStyle}" Margin="0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Top" Margin="0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBoxStyle}" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Margin="0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Operating System:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OperatingSystem, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBoxStyle}" Margin="0,8"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- System Settings -->
                    <StackPanel x:Name="SystemSettings" Visibility="Collapsed">
                        <TextBlock Text="System Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="PROCESSOR" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU Count:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <Slider Value="{Binding CpuCount}" Minimum="1" Maximum="32" Width="300" VerticalAlignment="Center" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="{Binding CpuCount}" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="MEMORY" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Base Memory:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <Slider Value="{Binding MemoryMB}" Minimum="256" Maximum="16384" Width="300" VerticalAlignment="Center" TickFrequency="256" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="{Binding MemoryDisplay, Mode=OneWay}" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="MMU CONFIGURATION" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="MMU Enabled:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding MMUEnabled}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Page Size:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <ComboBox SelectedValue="{Binding PageSizeKB}" Width="150" VerticalAlignment="Center">
                                        <ComboBoxItem Content="4 KB" Tag="4"/>
                                        <ComboBoxItem Content="8 KB" Tag="8"/>
                                        <ComboBoxItem Content="16 KB" Tag="16" IsSelected="True"/>
                                        <ComboBoxItem Content="64 KB" Tag="64"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Display Settings -->
                    <StackPanel x:Name="DisplaySettings" Visibility="Collapsed">
                        <TextBlock Text="Display Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="VIDEO MEMORY" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Video Memory:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <Slider Value="{Binding VideoMemoryMB}" Minimum="8" Maximum="256" Width="300" VerticalAlignment="Center" TickFrequency="8" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="{Binding VideoMemoryMB, StringFormat='{}{0} MB', Mode=OneWay}" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="3D Acceleration:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding Enable3DAcceleration}" VerticalAlignment="Center" Margin="0,8"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Storage Settings -->
                    <StackPanel x:Name="StorageSettings" Visibility="Collapsed">
                        <TextBlock Text="Storage Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="HARD DISK DRIVES" Style="{StaticResource ModernGroupBox}">
                            <StackPanel>
                                <Button Content="&#x2795; Add Hard Disk" 
                                        Command="{Binding AddDiskCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12"/>

                                <ItemsControl ItemsSource="{Binding DiskImages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BackgroundLightBrush}" 
                                                    BorderBrush="{StaticResource BorderBrush}" 
                                                    BorderThickness="1" 
                                                    Padding="12" 
                                                    Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="HDD">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Path}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                                                        <TextBlock Text="Controller:" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Controller}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" | Port " Style="{StaticResource SecondaryTextStyle}" Margin="8,0,0,0"/>
                                                        <TextBlock Text="{Binding Port}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" | " Style="{StaticResource SecondaryTextStyle}" Margin="8,0,0,0"/>
                                                        <TextBlock Text="{Binding Type}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                                                        <Button Content="Browse..." 
                                                                Command="{Binding DataContext.BrowseDiskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ToolbarButtonStyle}"
                                                                Padding="8,4"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Remove" 
                                                                Command="{Binding DataContext.RemoveDiskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ToolbarButtonStyle}"
                                                                Padding="8,4"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No hard disk images attached" 
                                           Margin="0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiskImages.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="CD/DVD DRIVES" Style="{StaticResource ModernGroupBox}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Use ISO images to boot from CD-ROM or install operating systems."
                                           Style="{StaticResource SecondaryTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>
                                
                                <Button Content="&#x2795; Add CD/DVD Drive (ISO)" 
                                        Command="{Binding AddCDRomCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12"/>

                                <ItemsControl ItemsSource="{Binding DiskImages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BackgroundLightBrush}" 
                                                    BorderBrush="{StaticResource AccentBlueBrush}" 
                                                    BorderThickness="2" 
                                                    Padding="12" 
                                                    Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="CD-ROM">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="&#x1F4BF; " Style="{StaticResource NormalTextStyle}" FontSize="20" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Path}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                                                        <TextBlock Text="Controller:" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Controller}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" | Port " Style="{StaticResource SecondaryTextStyle}" Margin="8,0,0,0"/>
                                                        <TextBlock Text="{Binding Port}" Style="{StaticResource NormalTextStyle}" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" | Read-Only" Style="{StaticResource SecondaryTextStyle}" Margin="8,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                                                        <Button Content="Browse ISO..." 
                                                                Command="{Binding DataContext.BrowseDiskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ToolbarButtonStyle}"
                                                                Padding="8,4"
                                                                Margin="0,0,8,0"/>
                                                        <Button Content="Remove" 
                                                                Command="{Binding DataContext.RemoveDiskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ToolbarButtonStyle}"
                                                                Padding="8,4"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No CD/DVD drives attached" 
                                           Margin="0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiskImages.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Network Settings -->
                    <StackPanel x:Name="NetworkSettings" Visibility="Collapsed">
                        <TextBlock Text="Network Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="NETWORK ADAPTER" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Enable Network:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding NetworkEnabled}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Adapter Type:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Text="{Binding NetworkAdapter}" Width="250" HorizontalAlignment="Left" IsEnabled="{Binding NetworkEnabled}" Margin="0,8">
                                    <ComboBoxItem Content="Intel PRO/1000 MT Desktop"/>
                                    <ComboBoxItem Content="Intel PRO/1000 T Server"/>
                                    <ComboBoxItem Content="AMD PCNet-PCI II"/>
                                    <ComboBoxItem Content="AMD PCNet-FAST III"/>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Attached to:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" Text="{Binding NetworkMode}" Width="250" HorizontalAlignment="Left" IsEnabled="{Binding NetworkEnabled}" Margin="0,8">
                                    <ComboBoxItem Content="NAT"/>
                                    <ComboBoxItem Content="Bridged Adapter"/>
                                    <ComboBoxItem Content="Internal Network"/>
                                    <ComboBoxItem Content="Host-only Adapter"/>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="MAC Address:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <TextBox Text="{Binding MacAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsTextBoxStyle}" Width="200" IsEnabled="{Binding NetworkEnabled}"/>
                                    <Button Content="Generate" 
                                            Command="{Binding GenerateMacCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Padding="12,6"
                                            Margin="8,0,0,0"
                                            IsEnabled="{Binding NetworkEnabled}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Performance Settings -->
                    <StackPanel x:Name="PerformanceSettings" Visibility="Collapsed">
                        <TextBlock Text="Performance Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="EXECUTION" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Execution Cap:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,8">
                                    <Slider Value="{Binding ExecutionCap}" Minimum="1" Maximum="100" Width="300" VerticalAlignment="Center" TickFrequency="5" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="{Binding ExecutionCap, StringFormat='{}{0}%', Mode=OneWay}" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Hotplug:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableCPUHotplug}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Enable PAE/NX:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding EnablePAE}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Nested VT-x/AMD-V:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding EnableNestedVT}" VerticalAlignment="Center" Margin="0,8"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- Advanced Settings -->
                    <StackPanel x:Name="AdvancedSettings" Visibility="Collapsed">
                        <TextBlock Text="Advanced Settings"
                                   Style="{StaticResource HeaderTextStyle}"
                                   Margin="0,0,0,20"/>

                        <GroupBox Header="FEATURES" Style="{StaticResource ModernGroupBox}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Enable Profiler:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableProfiler}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Enable Debugger:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableDebugger}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Enable Snapshots:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding EnableSnapshot}" VerticalAlignment="Center" Margin="0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pause on Start:" Style="{StaticResource NormalTextStyle}" VerticalAlignment="Center" Margin="0,8"/>
                                <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding PauseOnStart}" VerticalAlignment="Center" Margin="0,8"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Action Buttons -->
        <Border Grid.Row="1"
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" 
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="24,10"
                        Margin="0,0,12,0"
                        IsDefault="True"/>
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="24,10"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
