<Window x:Class="guideXOS_Hypervisor_GUI.Views.SnapshotManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:guideXOS_Hypervisor_GUI.ViewModels"
        xmlns:converters="clr-namespace:guideXOS_Hypervisor_GUI.Converters"
        mc:Ignorable="d"
        Title="Snapshot Manager" 
        Height="700" Width="1000"
        Background="{StaticResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        
        <!-- TreeViewItem style for snapshots -->
        <Style x:Key="SnapshotTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Hierarchical template for snapshot tree -->
        <HierarchicalDataTemplate x:Key="SnapshotTreeTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="3">
                <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                    <TextBlock Text="{Binding FormattedDate}" 
                               Style="{StaticResource SecondaryTextStyle}" 
                               FontSize="10"
                               Visibility="{Binding IsCurrentState, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Toolbar -->
        <Border Grid.Row="0" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Take Snapshot" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding CreateSnapshotDialogCommand}"
                            ToolTip="Create a new snapshot of the current state"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>
                    <Button Content="Restore" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RestoreSnapshotCommand}"
                            ToolTip="Restore the selected snapshot"/>
                    <Button Content="Delete" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding DeleteSnapshotCommand}"
                            ToolTip="Delete the selected snapshot"/>
                    <Button Content="Delete All" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding DeleteSnapshotAndChildrenCommand}"
                            ToolTip="Delete the selected snapshot and all its children"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>
                    <Button Content="Details" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ShowSnapshotDetailsCommand}"
                            ToolTip="Show snapshot details"/>
                    <Button Content="Clone" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding CloneSnapshotCommand}"
                            ToolTip="Clone VM from this snapshot"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Refresh" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh snapshot list"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Snapshot Tree -->
            <Border Grid.Column="0" 
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <!-- Tree Header -->
                    <Border DockPanel.Dock="Top" 
                            Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <Grid>
                            <TextBlock Text="Snapshots" 
                                       Style="{StaticResource HeaderTextStyle}" 
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Snapshot Statistics -->
                    <Border DockPanel.Dock="Bottom"
                            Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Total Snapshots" Style="{StaticResource SecondaryTextStyle}" FontSize="10"/>
                                <TextBlock Text="{Binding TotalSnapshots}" Style="{StaticResource NormalTextStyle}" FontWeight="Medium"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total Size" Style="{StaticResource SecondaryTextStyle}" FontSize="10"/>
                                <TextBlock Text="{Binding TotalSize}" Style="{StaticResource NormalTextStyle}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Snapshot Tree -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                        <TreeView ItemsSource="{Binding SnapshotTreeRoot}"
                                  ItemTemplate="{StaticResource SnapshotTreeTemplate}"
                                  ItemContainerStyle="{StaticResource SnapshotTreeItemStyle}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectedItemChanged="TreeView_SelectedItemChanged">
                        </TreeView>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>
            
            <!-- Right Panel - Snapshot Details -->
            <Border Grid.Column="2" 
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <!-- Details Header -->
                    <Border DockPanel.Dock="Top" 
                            Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <TextBlock Text="Snapshot Details" 
                                   Style="{StaticResource HeaderTextStyle}" 
                                   FontSize="14"/>
                    </Border>
                    
                    <!-- Details Content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
                        <StackPanel>
                            <!-- VM Name -->
                            <TextBlock Text="{Binding VMName}" 
                                       Style="{StaticResource HeaderTextStyle}" 
                                       FontSize="16"
                                       Margin="0,0,0,15"/>
                            
                            <!-- Selected Snapshot Info -->
                            <Border Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="15"
                                    Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Selected Snapshot" 
                                               Style="{StaticResource SecondaryTextStyle}" 
                                               FontSize="11"
                                               Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="{Binding SelectedSnapshotDetails}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               TextWrapping="Wrap"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Action Buttons -->
                            <StackPanel Orientation="Vertical">
                                <Button Content="Restore This Snapshot" 
                                        Command="{Binding RestoreSnapshotCommand}"
                                        IsEnabled="{Binding CanRestore}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Padding="15,10"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,10"/>
                                
                                <Button Content="Delete This Snapshot" 
                                        Command="{Binding DeleteSnapshotCommand}"
                                        IsEnabled="{Binding CanDelete}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Padding="15,10"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,10"/>
                                
                                <Button Content="Delete Snapshot and Children" 
                                        Command="{Binding DeleteSnapshotAndChildrenCommand}"
                                        IsEnabled="{Binding CanDelete}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Padding="15,10"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,10"/>
                                
                                <Separator Margin="0,10"/>
                                
                                <Button Content="Clone VM from Snapshot" 
                                        Command="{Binding CloneSnapshotCommand}"
                                        IsEnabled="{Binding CanRestore}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Padding="15,10"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Info Panel -->
                            <Border Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="15"
                                    Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="Snapshot Information" 
                                               Style="{StaticResource HeaderTextStyle}" 
                                               FontSize="12"
                                               Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" 
                                               Style="{StaticResource SecondaryTextStyle}"
                                               FontSize="11"
                                               xml:space="preserve">Snapshots capture the complete state of your VM at a specific point in time

You can restore to any snapshot to return to that state

Deleting a snapshot merges its changes with its parent

Current State represents the live running VM</TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           Style="{StaticResource SecondaryTextStyle}"/>
            </Grid>
        </Border>
        
        <!-- Create Snapshot Dialog Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3" 
              Background="#80000000"
              Visibility="{Binding ShowCreateDialog, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Width="500"
                    Padding="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Create Snapshot" 
                               Style="{StaticResource HeaderTextStyle}" 
                               FontSize="18"
                               Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Snapshot Name:" 
                               Style="{StaticResource SecondaryTextStyle}"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewSnapshotName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxStyle}"
                             Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Description (Optional):" 
                               Style="{StaticResource SecondaryTextStyle}"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewSnapshotDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" 
                                Command="{Binding CancelCreateSnapshotCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Padding="20,8"
                                Margin="0,0,10,0"/>
                        <Button Content="Create" 
                                Command="{Binding ConfirmCreateSnapshotCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Padding="20,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
