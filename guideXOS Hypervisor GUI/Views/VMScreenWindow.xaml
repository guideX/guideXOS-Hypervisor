<Window x:Class="guideXOS_Hypervisor_GUI.Views.VMScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:guideXOS_Hypervisor_GUI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="540" Width="680"
        MinHeight="480" MinWidth="640"
        Background="{StaticResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="ScreenToolbarButton">
            <Setter Property="Background" Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="? Fullscreen" 
                        Style="{StaticResource ScreenToolbarButton}"
                        Command="{Binding FullscreenCommand}"
                        ToolTip="Toggle fullscreen mode"/>
                
                <Separator Width="8" Background="Transparent"/>
                
                <Button Content="?? 100%" 
                        Style="{StaticResource ScreenToolbarButton}"
                        Command="{Binding ResetScaleCommand}"
                        ToolTip="Reset zoom to 100%"/>
                
                <Separator Width="8" Background="Transparent"/>
                
                <TextBlock Text="{Binding ScreenWidth, StringFormat='Resolution: {0}'}" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="8,0,0,0"/>
                <TextBlock Text="x" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="2,0"/>
                <TextBlock Text="{Binding ScreenHeight}" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,0,8,0"/>
            </StackPanel>
        </Border>

        <!-- VM Screen Display -->
        <Border Grid.Row="1" 
                Background="Black"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0">
            <Viewbox Stretch="Uniform">
                <Grid Width="{Binding ScreenWidth}" 
                      Height="{Binding ScreenHeight}">
                    <Image Source="{Binding ScreenBitmap}"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Width="{Binding ScreenWidth}"
                           Height="{Binding ScreenHeight}"/>
                    
                    <!-- Overlay for when VM is not running -->
                    <Border Background="#AA000000" 
                            Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="?" 
                                       FontSize="48"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Virtual Machine Paused" 
                                       FontSize="18"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Start the VM to see its display" 
                                       FontSize="14"
                                       Foreground="#CCFFFFFF"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Viewbox>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="VM: " 
                               Foreground="{StaticResource ForegroundBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding VmName}" 
                               Foreground="{StaticResource ForegroundBrush}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Ellipse Width="8" Height="8" 
                             Margin="0,0,4,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF666666"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#FF00CC00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Stopped"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Running"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
