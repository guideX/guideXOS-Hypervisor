<Window x:Class="guideXOS_Hypervisor_GUI.Views.DebuggerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:guideXOS_Hypervisor_GUI.ViewModels"
        xmlns:converters="clr-namespace:guideXOS_Hypervisor_GUI.Converters"
        mc:Ignorable="d"
        Title="IA-64 VM Debugger" 
        Height="900" Width="1400"
        Background="{StaticResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Toolbar -->
        <Border Grid.Row="0" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Control Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Attach" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding AttachCommand}"
                            ToolTip="Attach debugger to VM"/>
                    <Button Content="Detach" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding DetachCommand}"
                            ToolTip="Detach debugger from VM"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0"/>
                    <Button Content="Step" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding StepInstructionCommand}"
                            ToolTip="Execute single instruction"/>
                    <Button Content="Continue" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ContinueCommand}"
                            ToolTip="Continue execution"/>
                    <Button Content="Pause" 
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding PauseCommand}"
                            ToolTip="Pause execution"/>
                </StackPanel>
                
                <!-- Status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status:" 
                               Style="{StaticResource SecondaryTextStyle}"
                               Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Style="{StaticResource NormalTextStyle}"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Registers and Special Registers -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Special Registers -->
                <Border Grid.Row="0" 
                        Background="{StaticResource BackgroundMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Special Registers" 
                                   Style="{StaticResource HeaderTextStyle}"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP:" Style="{StaticResource SecondaryTextStyle}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InstructionPointerHex}" Style="{StaticResource NormalTextStyle}" Margin="10,3,0,3" FontFamily="Consolas"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="CFM:" Style="{StaticResource SecondaryTextStyle}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CFMHex}" Style="{StaticResource NormalTextStyle}" Margin="10,3,0,3" FontFamily="Consolas"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="PSR:" Style="{StaticResource SecondaryTextStyle}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PSRHex}" Style="{StaticResource NormalTextStyle}" Margin="10,3,0,3" FontFamily="Consolas"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Register Viewer Tabs -->
                <Border Grid.Row="1" 
                        Background="{StaticResource BackgroundMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TabControl Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedRegisterTab}">
                        <!-- General Registers -->
                        <TabItem Header="GR[0-127]">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CPUState.GeneralRegisters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource SecondaryTextStyle}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding HexValue}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- Floating Point Registers -->
                        <TabItem Header="FR[0-127]">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CPUState.FloatingPointRegisters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource SecondaryTextStyle}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding HexValue}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- Predicate Registers -->
                        <TabItem Header="PR[0-63]">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CPUState.PredicateRegisters}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="5" Padding="5" Background="{StaticResource BackgroundLightBrush}" CornerRadius="3">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource SecondaryTextStyle}" Width="50"/>
                                                    <TextBlock Text="{Binding DisplayValue}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas" Margin="5,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- Branch Registers -->
                        <TabItem Header="BR[0-7]">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CPUState.BranchRegisters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource SecondaryTextStyle}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding HexValue}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
            
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>
            
            <!-- Right Panel - Memory, Breakpoints, Watchpoints -->
            <Grid Grid.Column="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Memory Viewer -->
                <Border Grid.Row="0" 
                        Background="{StaticResource BackgroundMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,0,0,5">
                    <DockPanel>
                        <!-- Memory Controls -->
                        <Border DockPanel.Dock="Top" 
                                Background="{StaticResource BackgroundLightBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Memory Viewer" Style="{StaticResource HeaderTextStyle}" FontSize="14" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="Address:" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox Text="{Binding MemoryViewAddress, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="150" 
                                             VerticalAlignment="Center"
                                             Margin="0,0,5,0"
                                             Style="{StaticResource TextBoxStyle}"/>
                                    <Button Content="Go" 
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding GoToAddressCommand}"
                                            ToolTip="Jump to address"/>
                                    <Button Content="Refresh" 
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding RefreshMemoryCommand}"
                                            ToolTip="Refresh memory view"
                                            Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Memory Content -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                            <ItemsControl ItemsSource="{Binding MemoryRegions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="400"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding HexAddress}" Style="{StaticResource SecondaryTextStyle}" FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HexDump}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas" Margin="10,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding AsciiDump}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="{StaticResource BorderBrush}"/>
                
                <!-- Breakpoints and Watchpoints -->
                <Grid Grid.Row="2" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Breakpoints -->
                    <Border Grid.Column="0" 
                            Background="{StaticResource BackgroundMediumBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DockPanel>
                            <!-- Breakpoint Controls -->
                            <Border DockPanel.Dock="Top" 
                                    Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,8">
                                <Grid>
                                    <TextBlock Text="Breakpoints" Style="{StaticResource HeaderTextStyle}" FontSize="14" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <!-- Add Breakpoint -->
                            <Border DockPanel.Dock="Bottom" 
                                    Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding BreakpointAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxStyle}"
                                             Margin="0,0,5,0"/>
                                    <Button Grid.Column="1" 
                                            Content="Add" 
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding AddBreakpointCommand}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Breakpoint List -->
                            <ListView ItemsSource="{Binding Breakpoints}"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding IsEnabled}"
                                                      Command="{Binding DataContext.ToggleBreakpointCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding HexAddress}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" Margin="10,0"/>
                                            <Button Grid.Column="3" 
                                                    Content="?" 
                                                    Style="{StaticResource ToolbarButtonStyle}"
                                                    Command="{Binding DataContext.RemoveBreakpointCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove breakpoint"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </Border>
                    
                    <!-- Watchpoints -->
                    <Border Grid.Column="2" 
                            Background="{StaticResource BackgroundMediumBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DockPanel>
                            <!-- Watchpoint Controls -->
                            <Border DockPanel.Dock="Top" 
                                    Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,8">
                                <Grid>
                                    <TextBlock Text="Watchpoints" Style="{StaticResource HeaderTextStyle}" FontSize="14" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <!-- Add Watchpoint -->
                            <Border DockPanel.Dock="Bottom" 
                                    Background="{StaticResource BackgroundLightBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding WatchpointAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxStyle}"
                                             Margin="0,0,5,0"/>
                                    <Button Grid.Column="1" 
                                            Content="Add" 
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding AddWatchpointCommand}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Watchpoint List -->
                            <ListView ItemsSource="{Binding Watchpoints}"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding IsEnabled}"
                                                      Command="{Binding DataContext.ToggleWatchpointCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding HexAddress}" Style="{StaticResource NormalTextStyle}" FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding TypeString}" Style="{StaticResource SecondaryTextStyle}" FontSize="10"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" Margin="10,0"/>
                                            <Button Grid.Column="3" 
                                                    Content="?" 
                                                    Style="{StaticResource ToolbarButtonStyle}"
                                                    Command="{Binding DataContext.RemoveWatchpointCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove watchpoint"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="IA-64 VM Debugger" Style="{StaticResource SecondaryTextStyle}"/>
                <TextBlock Grid.Column="2" Text="{Binding VMId}" Style="{StaticResource SecondaryTextStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
